# Shared
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string

# Postgres
POSTGRES_USER=skilling
POSTGRES_PASSWORD=skilling
POSTGRES_DB=skilling_mmo
DATABASE_URL=postgresql://skilling:skilling@postgres:5432/skilling_mmo?schema=public

# Redis (optional locally — use compose profile `full`)
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

# API
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=*

# Game server (Colyseus)
GAME_PORT=2567
GAME_HOST=0.0.0.0

# Worker
WORKER_CONCURRENCY=2

# Client (Vite build / Caddy)
# API is reverse-proxied at /api/* (Caddy strip). Leave VITE_WS_URL empty for same-origin Colyseus via Caddy.
VITE_API_URL=/api
VITE_WS_URL=

# Prod / GHCR
GHCR_OWNER=your-github-user-or-org

# HTTPS (Caddy + Let's Encrypt)
# Use your real hostname (not an IP). DNS A/AAAA must point at this VM first.
# Example: DOMAIN=play.yourgame.com
DOMAIN=localhost
# Optional contact email for Let's Encrypt expiry notices
ACME_EMAIL=
