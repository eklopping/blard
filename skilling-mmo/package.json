{
  "name": "skilling-mmo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run dev -w @skilling-mmo/api",
    "dev:game": "npm run dev -w @skilling-mmo/game-server",
    "dev:worker": "npm run dev -w @skilling-mmo/worker",
    "dev:client": "npm run dev -w @skilling-mmo/client",
    "db:generate": "npm run generate -w @skilling-mmo/db",
    "db:migrate": "npm run migrate -w @skilling-mmo/db",
    "db:deploy": "npm run deploy -w @skilling-mmo/db"
  },
  "engines": {
    "node": ">=20"
  }
}
